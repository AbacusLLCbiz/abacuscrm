generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  STAFF
  CLIENT
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  PROSPECT
}

enum EntityType {
  INDIVIDUAL
  SOLE_PROPRIETOR
  LLC
  S_CORP
  C_CORP
  PARTNERSHIP
  NON_PROFIT
  OTHER
}

enum DocumentDirection {
  INBOUND
  OUTBOUND
}

enum DocumentStatus {
  PENDING
  REVIEWED
  ARCHIVED
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum MeetingType {
  IN_PERSON
  ZOOM
  GOOGLE_MEET
  PHONE
}

enum ReminderChannel {
  EMAIL
  SMS
}

enum ReminderStatus {
  SCHEDULED
  SENT
  FAILED
  CANCELLED
}

enum AutomationTrigger {
  DOCUMENT_UPLOADED
  DOCUMENT_REQUEST_DUE
  APPOINTMENT_BOOKED
  APPOINTMENT_CONFIRMED
  APPOINTMENT_CANCELLED
  APPOINTMENT_REMINDER_24H
  APPOINTMENT_REMINDER_1H
  CLIENT_CREATED
  DOCUMENT_REVIEWED
  CUSTOM_DATE
}

enum AutomationAction {
  SEND_EMAIL
  SEND_SMS
  REQUEST_DOCUMENTS
  CREATE_REMINDER
  WEBHOOK
}

// ─── Auth (NextAuth v5) ───────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  phone         String?
  role          UserRole  @default(STAFF)
  isActive      Boolean   @default(true)
  avatarUrl     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]
  otpCodes      OtpCode[]

  ownedClients    Client[]      @relation("AssignedStaff")
  appointments    Appointment[] @relation("StaffAppointments")
  calendarToken   CalendarToken?
  phoneCalls      PhoneCall[]   @relation("StaffCalls")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  scope             String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model OtpCode {
  id        String   @id @default(cuid())
  userId    String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Clients ─────────────────────────────────────────────────────────────────

model Client {
  id              String       @id @default(cuid())
  portalUserId    String?      @unique
  assignedToId    String
  status          ClientStatus @default(ACTIVE)

  firstName       String
  lastName        String
  email           String       @unique
  phone           String?
  company         String?
  entityType      EntityType?

  taxId           String?
  fiscalYearEnd   String?
  services        String[]
  tags            String[]

  street          String?
  city            String?
  state           String?
  zip             String?
  country         String?      @default("US")

  notes           String?
  portalEnabled   Boolean      @default(false)

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  assignedTo       User              @relation("AssignedStaff", fields: [assignedToId], references: [id])
  documents        Document[]
  appointments     Appointment[]
  reminders        Reminder[]
  automationLogs   AutomationLog[]
  documentRequests DocumentRequest[]
  phoneCalls       PhoneCall[]
}

// ─── Document Folders ─────────────────────────────────────────────────────────

model DocumentFolder {
  id          String     @id @default(cuid())
  name        String
  description String?
  color       String?    @default("#1E40AF")
  icon        String?    @default("folder")
  sortOrder   Int        @default(0)
  isDefault   Boolean    @default(false)
  createdAt   DateTime   @default(now())

  documents   Document[]
}

// ─── Documents ───────────────────────────────────────────────────────────────

model Document {
  id            String            @id @default(cuid())
  clientId      String
  folderId      String?
  requestId     String?
  name          String
  r2Key         String            @unique
  mimeType      String
  sizeBytes     Int
  direction     DocumentDirection
  status        DocumentStatus    @default(PENDING)
  uploadedById  String?
  description   String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  client        Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  folder        DocumentFolder?   @relation(fields: [folderId], references: [id])
  request       DocumentRequest?  @relation(fields: [requestId], references: [id])
}

model DocumentRequest {
  id          String    @id @default(cuid())
  clientId    String
  title       String
  description String?
  dueDate     DateTime?
  fulfilled   Boolean   @default(false)
  fulfilledAt DateTime?
  createdAt   DateTime  @default(now())

  client      Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  documents   Document[]
}

// ─── Scheduler ───────────────────────────────────────────────────────────────

model EventType {
  id                   String        @id @default(cuid())
  slug                 String        @unique
  title                String
  description          String?
  durationMinutes      Int           @default(60)
  color                String        @default("#1E40AF")
  isActive             Boolean       @default(true)
  meetingTypes         MeetingType[]
  bufferMinutes        Int           @default(15)
  maxBookingsPerDay    Int?
  requiresConfirmation Boolean       @default(false)
  locationDetails      String?
  zoomLink             String?
  googleMeetLink       String?
  questions            Json?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  availability         Availability[]
  appointments         Appointment[]
}

model Availability {
  id          String    @id @default(cuid())
  eventTypeId String
  dayOfWeek   Int
  startTime   String
  endTime     String
  timezone    String    @default("America/New_York")

  eventType   EventType @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)
}

model Appointment {
  id              String            @id @default(cuid())
  clientId        String
  eventTypeId     String
  staffUserId     String
  startAt         DateTime
  endAt           DateTime
  timezone        String
  status          AppointmentStatus @default(PENDING)
  meetingType     MeetingType
  meetingUrl      String?
  meetingPhone    String?
  responses       Json?
  googleEventId   String?
  msEventId       String?
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  client          Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  eventType       EventType         @relation(fields: [eventTypeId], references: [id])
  staffUser       User              @relation("StaffAppointments", fields: [staffUserId], references: [id])
}

// ─── Reminders ───────────────────────────────────────────────────────────────

model Reminder {
  id              String          @id @default(cuid())
  clientId        String
  channel         ReminderChannel
  status          ReminderStatus  @default(SCHEDULED)
  subject         String?
  body            String
  scheduledAt     DateTime
  sentAt          DateTime?
  error           String?
  appointmentId   String?
  documentId      String?
  createdAt       DateTime        @default(now())

  client          Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

// ─── Automations ─────────────────────────────────────────────────────────────

model AutomationRule {
  id                String            @id @default(cuid())
  name              String
  description       String?
  isActive          Boolean           @default(true)
  trigger           AutomationTrigger
  triggerDaysBefore Int?
  triggerDateField  String?
  conditions        Json?
  action            AutomationAction
  actionConfig      Json
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  logs              AutomationLog[]
}

model AutomationLog {
  id              String         @id @default(cuid())
  ruleId          String
  clientId        String
  triggerPayload  Json
  actionResult    Json?
  success         Boolean
  error           String?
  executedAt      DateTime       @default(now())

  rule            AutomationRule @relation(fields: [ruleId], references: [id])
  client          Client         @relation(fields: [clientId], references: [id])
}

// ─── Phone Calls (Twilio Voice) ──────────────────────────────────────────────

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum CallStatus {
  INITIATED
  RINGING
  IN_PROGRESS
  COMPLETED
  FAILED
  BUSY
  NO_ANSWER
  CANCELLED
}

model PhoneCall {
  id              String        @id @default(cuid())
  clientId        String?
  staffUserId     String?
  twilioCallSid   String        @unique
  direction       CallDirection
  status          CallStatus    @default(INITIATED)
  fromNumber      String
  toNumber        String
  durationSeconds Int?
  recordingUrl    String?
  transcription   String?
  notes           String?
  startedAt       DateTime      @default(now())
  endedAt         DateTime?

  client          Client?       @relation(fields: [clientId], references: [id])
  staffUser       User?         @relation("StaffCalls", fields: [staffUserId], references: [id])
}

// ─── Analytics ───────────────────────────────────────────────────────────────

model PageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  sessionId String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([path])
}

// ─── Calendar OAuth ───────────────────────────────────────────────────────────

model CalendarToken {
  id            String   @id @default(cuid())
  userId        String   @unique
  provider      String
  accessToken   String
  refreshToken  String
  expiresAt     DateTime
  calendarId    String?
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
